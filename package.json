{
  "name": "opcom",
  "version": "0.1.6",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "bundle": "npm run build && node scripts/bundle.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:tui": "tsx --watch packages/cli/src/index.ts tui",
    "release": "node scripts/release.mjs"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^25.3.2",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.27.3",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
